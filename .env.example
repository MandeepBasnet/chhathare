# ─── Appwrite (SAME project as Khajum Chongbang) ───────────────────────────
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.itsoch.com/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=6a192900003bfd6eab99
# Server-side API key — NEVER commit the real value; keep .env out of git.
APPWRITE_API_KEY=

# ─── NEW database + buckets for the literature site ────────────────────────
NEXT_PUBLIC_APPWRITE_DATABASE_ID=chhathare-sahitya
# PDF bucket for downloadable/readable books (provisioned by the script below)
NEXT_PUBLIC_APPWRITE_BUCKET_BOOKS=sahitya-books
# Reused image buckets from the same project
NEXT_PUBLIC_APPWRITE_BUCKET_GALLERY=gallery-media
NEXT_PUBLIC_APPWRITE_BUCKET_GENERAL=general

# ─── Cross-site links (requirement #3) ─────────────────────────────────────
NEXT_PUBLIC_LINK_KHAJUM=https://khajumchongbang.org
# Defaults to the YouTube channel; set this when a standalone site goes live
NEXT_PUBLIC_LINK_SAWAYETHANG=

# ─── Site metadata ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Chhathare Limbu Sahitya
NEXT_PUBLIC_SITE_DESCRIPTION=Chhathare Limbu literature — Yakthung & Nepali works
NEXT_PUBLIC_SITE_URL=http://localhost:3000
